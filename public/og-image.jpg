  <text x="220" y="408" font-size="26" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:26px;font-weight:400;text-anchor:start;dominant-baseline:auto">Licensed Emergency Plumber in Springfield MO</text>
  <text x="220" y="446" font-size="22" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:22px;font-weight:400;text-anchor:start;dominant-baseline:auto">24/7 Fast Response · No Hidden Fees · Upfront Pricing</text>

  <!-- Phone number -->
  <rect x="220" y="478" width="340" height="60" rx="10" style="fill:rgb(232, 108, 47);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
