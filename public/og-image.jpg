  <!-- Badge 2: Stars -->
  <rect x="960" y="180" width="160" height="160" rx="16" fill="#162d56" style="fill:rgb(22, 45, 86);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="1040" y="248" font-size="22" text-anchor="middle" fill="#f5c842" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:22px;font-weight:700;text-anchor:middle;dominant-baseline:auto">★★★★★</text>
  <text x="1040" y="280" font-size="32" text-anchor="middle" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:32px;font-weight:700;text-anchor:middle;dominant-baseline:auto">4.8</text>
  <text x="1040" y="308" font-size="15" text-anchor="middle" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:15px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Google Rating</text>
  <text x="1040" y="326" font-size="14" text-anchor="middle" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:14px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Springfield MO</text>

  <!-- Badge 3: Licensed -->
  <rect x="780" y="360" width="160" height="100" rx="16" fill="#162d56" style="fill:rgb(22, 45, 86);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="860" y="402" font-size="15" text-anchor="middle" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:15px;font-weight:600;text-anchor:middle;dominant-baseline:auto">Licensed</text>
  <text x="860" y="422" font-size="15" text-anchor="middle" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:15px;font-weight:600;text-anchor:middle;dominant-baseline:auto">&amp; Insured</text>
  <text x="860" y="444" font-size="13" text-anchor="middle" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:13px;font-weight:400;text-anchor:middle;dominant-baseline:auto">State of Missouri</text>

  <!-- Badge 4: $0 -->
