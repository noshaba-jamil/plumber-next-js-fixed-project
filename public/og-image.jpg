  <!-- Bottom bar -->
  <rect x="0" y="580" width="1200" height="50" fill="#0a1628" style="fill:rgb(10, 22, 40);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="600" y="612" font-size="18" text-anchor="middle" style="fill:rgba(255, 255, 255, 0.7);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:18px;font-weight:400;text-anchor:middle;dominant-baseline:auto">springfieldmoplumber.com · Available NOW · Dispatching to Springfield Area</text>

  <!-- Bottom left accent dot -->
  <circle cx="48" cy="605" r="6" style="fill:rgb(232, 108, 47);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
